[Unit]
Description=Voter Extraction Flask Application
After=network.target

[Service]
Type=simple
# NOTE: Replace <USERNAME> with your actual username when installing
# The setup-service.sh script will do this automatically
User=<USERNAME>
Group=<USERNAME>
WorkingDirectory=/home/<USERNAME>/ocr/voter_extraction_without_API/backend/python-service
Environment="PATH=/home/<USERNAME>/ocr/voter_extraction_without_API/backend/python-service/venv/bin"
ExecStart=/home/<USERNAME>/ocr/voter_extraction_without_API/backend/python-service/venv/bin/python3 app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=voter-extraction

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Resource limits (adjust as needed)
LimitNOFILE=65536

# Environment variables
Environment="HOST=0.0.0.0"
Environment="PORT=5000"

[Install]
WantedBy=multi-user.target

